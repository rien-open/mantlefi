# MantleFi keys — the deterministic engine (scan/judge/report + the verdict cards) needs NO key.
# Keys only unlock the LLM phrasing layers. Copy to `.env` and fill in (or set as env vars on
# your host). .env is gitignored — never commit a real key.

# Free Groq key — the PRIMARY LLM for the chat reply + the daily-crew wording (strong + fast:
# gpt-oss-120b for what you read, llama-3.3-70b for the loop). Get one at https://console.groq.com
GROQ_API_KEY=

# Free NVIDIA NIM key (OpenAI-compatible) — the AUTOMATIC FALLBACK for the LLM layer (maverick).
# Get one at https://build.nvidia.com  ·  either key alone works; setting both is most reliable.
NVIDIA_NIM_API_KEY=

# Optional: Telegram bot token from @BotFather (only if you run the dormant telegram_bot.py).
TELEGRAM_BOT_TOKEN=
