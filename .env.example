# MantleFi keys — the deterministic engine (scan/judge/report + the verdict cards) needs NO key.
# Keys only unlock the LLM phrasing layers. Copy to `.env` and fill in (or set as env vars on
# your host). .env is gitignored — never commit a real key.

# Free NVIDIA NIM key (OpenAI-compatible) — the friendly one-liner + the survey crew narration.
# Get one at https://build.nvidia.com
NVIDIA_NIM_API_KEY=

# Optional free Groq key — makes the interactive chat loop faster (falls back to NIM without it).
# Get one at https://console.groq.com
GROQ_API_KEY=

# Optional: Telegram bot token from @BotFather (only if you run the dormant telegram_bot.py).
TELEGRAM_BOT_TOKEN=
